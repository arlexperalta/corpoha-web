---
import Layout from './Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import StickyWhatsApp from '@components/StickyWhatsApp.astro';

interface Props {
  title: string;
  description?: string;
  lastUpdated?: string;
}

const { title, description, lastUpdated } = Astro.props;
---
<Layout title={`${title} | Corporación HA`} description={description}>
  <Header />
  <main class="legal-main">
    <div class="container legal-container">
      <header class="legal-header">
        <span class="subhead">Legal</span>
        <h1>{title}</h1>
        {lastUpdated && <p class="legal-updated">Última actualización: {lastUpdated}</p>}
      </header>

      <article class="legal-content">
        <slot />
      </article>
    </div>
  </main>
  <Footer />
  <StickyWhatsApp />
</Layout>

<style>
  .legal-main {
    padding-block: var(--space-16) var(--space-24);
    background: var(--surface-0);
  }

  .legal-container {
    max-width: 760px;
  }

  .legal-header {
    padding-bottom: var(--space-12);
    border-bottom: 1px solid var(--border-subtle);
    margin-bottom: var(--space-12);
  }

  .legal-header h1 {
    margin-top: var(--space-3);
    font-size: var(--fs-h1);
  }

  .legal-updated {
    margin-top: var(--space-4);
    color: var(--text-secondary);
    font-size: var(--fs-caption);
    letter-spacing: 0.05em;
  }

  .legal-content :global(h2) {
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
    font-size: var(--fs-h3);
  }

  .legal-content :global(h2:first-child) {
    margin-top: 0;
  }

  .legal-content :global(p) {
    margin-bottom: var(--space-4);
    color: var(--text-primary);
    line-height: 1.7;
  }

  .legal-content :global(ul),
  .legal-content :global(ol) {
    margin-bottom: var(--space-4);
    padding-left: var(--space-6);
    list-style: disc;
    color: var(--text-primary);
  }

  .legal-content :global(li) {
    margin-bottom: var(--space-2);
    line-height: 1.6;
  }

  .legal-content :global(a) {
    color: var(--text-primary);
    border-bottom: 1px solid var(--action-primary);
    padding-bottom: 1px;
  }

  .legal-content :global(a:hover) {
    color: var(--action-primary);
  }
</style>
