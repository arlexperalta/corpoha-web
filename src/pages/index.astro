---
import Layout from '@layouts/Layout.astro';
import ScrollProgress from '@components/ScrollProgress.astro';
import Header from '@components/Header.astro';
import Hero from '@components/Hero.astro';
import ServicesGrid from '@components/ServicesGrid.astro';
import PortfolioGrid from '@components/PortfolioGrid.astro';
import ProcessSteps from '@components/ProcessSteps.astro';
import AboutSection from '@components/AboutSection.astro';
import ContactBlock from '@components/ContactBlock.astro';
import Footer from '@components/Footer.astro';
import StickyWhatsApp from '@components/StickyWhatsApp.astro';
import ProjectLightbox from '@components/ProjectLightbox.astro';
---
<Layout>
  <ScrollProgress />
  <Header />
  <main>
    <Hero />
    <ServicesGrid />
    <PortfolioGrid />
    <ProcessSteps />
    <AboutSection />
    <ContactBlock />
  </main>
  <Footer />
  <StickyWhatsApp />
  <ProjectLightbox />
</Layout>
