---
import { processSteps } from '@data/process';
---
<section id="proceso" class="process">
  <div class="container">
    <div class="sec-head">
      <div>
        <div class="eyebrow sec-head__eyebrow" style="color: var(--amber);">Cómo trabajamos</div>
        <h2 class="sec-head__title">Cuatro pasos.<br/>Sin sorpresas.</h2>
      </div>
      <p class="sec-head__sub">
        Del diagnóstico al soporte postventa. Cada fase documentada,
        cada plazo cumplido.
      </p>
    </div>

    <div class="process__timeline">
      {processSteps.map((s) => (
        <div class="step">
          <div class="step__head">
            <div class="step__num">{s.number}</div>
            <div class="step__dot" aria-hidden="true"></div>
          </div>
          <h3 class="step__title">{s.title}</h3>
          <p class="step__desc">{s.description}</p>
          <div class="step__meta">→ {s.meta}</div>
        </div>
      ))}
    </div>
  </div>
</section>
