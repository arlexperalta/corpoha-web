---
import { processSteps } from '@data/process';
---
<section id="proceso" class="process">
  <div class="container">
    <header class="section-header">
      <span class="subhead">Cómo trabajamos</span>
      <h2>Cuatro pasos. Sin sorpresas.</h2>
      <p class="section-lead">
        Del diagnóstico al soporte postventa. Cada fase documentada, cada plazo cumplido.
      </p>
    </header>

    <ol class="process-list">
      {processSteps.map((step) => (
        <li class="process-step reveal">
          <span class="process-number">{step.number}</span>
          <div class="process-content">
            <h3 class="process-title">{step.title}</h3>
            <p class="process-description">{step.description}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .process {
    background: var(--surface-1);
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
  }

  .section-header {
    max-width: 720px;
    margin-bottom: var(--space-16);
  }

  .section-header h2 {
    margin-top: var(--space-3);
  }

  .section-lead {
    margin-top: var(--space-4);
    font-size: var(--fs-body-lg);
    color: var(--text-secondary);
  }

  .process-list {
    display: grid;
    gap: var(--space-8);
  }

  .process-step {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-block: var(--space-6);
    border-top: 1px solid var(--border-subtle);
    position: relative;
  }

  .process-number {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 800;
    color: var(--action-primary);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .process-title {
    font-size: var(--fs-h3);
    color: var(--text-heading);
  }

  .process-description {
    margin-top: var(--space-3);
    color: var(--text-secondary);
    max-width: 52ch;
  }

  @media (min-width: 768px) {
    .process-list {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-12);
    }

    .process-step {
      flex-direction: row;
      align-items: flex-start;
      gap: var(--space-6);
    }

    .process-number {
      flex-shrink: 0;
      min-width: 4.5rem;
    }
  }

  @media (min-width: 1200px) {
    .process-list {
      grid-template-columns: repeat(4, 1fr);
    }

    .process-step {
      flex-direction: column;
    }
  }
</style>
