---
---
<section id="nosotros" class="about">
  <div class="container">
    <div class="sec-head">
      <div>
        <div class="eyebrow sec-head__eyebrow" style="color: var(--amber);">Quiénes somos</div>
      </div>
    </div>

    <div class="about__grid">
      <div class="about__text">
        <h2>Construimos espacios que inspiran <em>y perduran.</em></h2>
        <p>
          Corporación HA es una empresa venezolana especializada en construcción y remodelación.
          Desde transformaciones residenciales hasta infraestructura nacional, usamos tecnología BIM
          y nos comprometemos con regulaciones locales para entregar proyectos que funcionan y permanecen.
        </p>
        <p>
          Gestionamos obras sin interrumpir tu operación. Cumplimos plazos incluso con urgencia.
          Acabados con estándares internacionales, ejecución con disciplina técnica local.
        </p>
      </div>

      <div class="about__stats" id="about-stats">
        <div class="about__stat">
          <div class="about__stat-num mono" data-target="12" data-suffix="+">
            <span class="stat-value">00</span>
            <span class="about__stat-unit">+</span>
          </div>
          <div class="about__stat-label">Obras entregadas</div>
        </div>
        <div class="about__stat">
          <div class="about__stat-num mono" data-target="4">
            <span class="stat-value">00</span>
          </div>
          <div class="about__stat-label">Categorías de proyecto</div>
        </div>
        <div class="about__stat">
          <div class="about__stat-num mono" data-target="16" data-suffix="+">
            <span class="stat-value">00</span>
            <span class="about__stat-unit">+</span>
          </div>
          <div class="about__stat-label">Años de experiencia</div>
        </div>
        <div class="about__stat">
          <div class="about__stat-num" style="font-size: clamp(28px, 3.5vw, 44px);">BIM</div>
          <div class="about__stat-label">Modelado 3D pre-obra</div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const statsContainer = document.getElementById('about-stats');
  if (statsContainer) {
    const animateCounter = (el: HTMLElement, target: number) => {
      const duration = 1200;
      const start = performance.now();
      const span = el.querySelector<HTMLElement>('.stat-value');
      if (!span) return;
      const tick = (t: number) => {
        const p = Math.min((t - start) / duration, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        const current = Math.round(target * eased);
        span.textContent = String(current).padStart(2, '0');
        if (p < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            statsContainer.querySelectorAll<HTMLElement>('[data-target]').forEach((el) => {
              const target = parseInt(el.dataset.target || '0', 10);
              if (target) animateCounter(el, target);
            });
            observer.disconnect();
          }
        });
      },
      { threshold: 0.3 }
    );
    observer.observe(statsContainer);
  }
</script>
