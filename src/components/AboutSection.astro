---
const stats = [
  { number: '12+', label: 'Obras entregadas', note: 'Rango de escalas' },
  { number: '04', label: 'Categorías', note: 'Comercial · Residencial · Industrial · Desarrollo' },
  { number: '04', label: 'Estados de Venezuela', note: 'Caracas · Miranda · Anzoátegui · DC' },
  { number: 'BIM', label: 'Modelado 3D pre-obra', note: 'Información de Construcción' },
];
---
<section id="nosotros" class="about section-dark bg-blueprint-dark">
  <div class="about-watermark" aria-hidden="true">
    <span class="watermark watermark--light watermark-parallax">05</span>
  </div>

  <div class="container">
    <header class="section-header">
      <div class="section-header-top">
        <span class="section-marker section-marker--light">Sección 05 · Nosotros</span>
        <span class="section-count">Corporación HA · desde Caracas</span>
      </div>
      <h2 class="about-title">
        Construimos espacios<br>
        <span class="accent">que inspiran y perduran.</span>
      </h2>
    </header>

    <div class="about-inner">
      <div class="about-content">
        <blockquote class="about-pullquote">
          <p>
            Gestionamos obras sin interrumpir tu operación.
            Cumplimos plazos incluso con urgencia.
          </p>
          <footer>
            <span class="hairline-mark" aria-hidden="true"></span>
            <span>Método Corpoha</span>
          </footer>
        </blockquote>

        <div class="about-body">
          <p>
            Corporación HA es una empresa venezolana especializada en construcción y
            remodelación. Desde transformaciones residenciales hasta infraestructura
            nacional, usamos tecnología BIM y nos comprometemos con regulaciones locales
            para entregar proyectos que funcionan y permanecen.
          </p>
          <p>
            Acabados con estándares internacionales, ejecución con disciplina técnica
            local. Cada obra entregada es una decisión de quedarnos, volver y
            responder.
          </p>
        </div>
      </div>

      <ul class="about-stats">
        {stats.map((stat, i) => (
          <li class="stat reveal-stagger" style={`animation-delay: ${i * 100}ms`}>
            <div class="stat-header">
              <span class="stat-index">{String(i + 1).padStart(2, '0')}</span>
            </div>
            <span class="stat-number">{stat.number}</span>
            <span class="stat-label">{stat.label}</span>
            <span class="stat-note">{stat.note}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .about {
    padding-block: var(--space-24);
    position: relative;
    overflow: hidden;
  }

  .about-watermark {
    position: absolute;
    bottom: -8vh;
    left: -6vw;
    pointer-events: none;
    z-index: 0;
  }

  .about-watermark .watermark {
    display: block;
    line-height: 0.85;
  }

  .about :global(.container) {
    position: relative;
    z-index: 1;
  }

  .section-header {
    max-width: 900px;
    margin-bottom: var(--space-16);
  }

  .section-header-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid color-mix(in oklch, var(--text-on-dark) 15%, transparent);
  }

  .section-count {
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--text-dim-on-dark);
    letter-spacing: var(--letter-spacing-technical);
    text-transform: uppercase;
  }

  .about-title {
    margin-top: var(--space-8);
    color: var(--text-on-dark);
    font-size: var(--fs-h1);
    line-height: 1.02;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  .about-title .accent {
    color: var(--action-primary);
  }

  .about-inner {
    display: grid;
    gap: var(--space-16);
  }

  .about-pullquote {
    padding: var(--space-8) 0;
    border-top: 1px solid color-mix(in oklch, var(--text-on-dark) 20%, transparent);
    border-bottom: 1px solid color-mix(in oklch, var(--text-on-dark) 20%, transparent);
  }

  .about-pullquote p {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: clamp(1.5rem, 1.2rem + 1.2vw, 2.25rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--text-on-dark);
    max-width: unset;
    text-wrap: balance;
  }

  .about-pullquote footer {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-6);
    font-family: var(--font-body);
    font-size: var(--fs-caption);
    font-weight: 500;
    color: var(--action-primary);
    letter-spacing: var(--letter-spacing-technical);
    text-transform: uppercase;
  }

  .hairline-mark {
    width: 32px;
    height: 1px;
    background: var(--action-primary);
  }

  .about-body {
    margin-top: var(--space-8);
    display: grid;
    gap: var(--space-5);
  }

  .about-body p {
    color: var(--text-dim-on-dark);
    font-size: var(--fs-body-lg);
    max-width: 58ch;
    line-height: 1.65;
  }

  .about-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border-top: 1px solid color-mix(in oklch, var(--text-on-dark) 25%, transparent);
    border-left: 1px solid color-mix(in oklch, var(--text-on-dark) 25%, transparent);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-8);
    border-right: 1px solid color-mix(in oklch, var(--text-on-dark) 25%, transparent);
    border-bottom: 1px solid color-mix(in oklch, var(--text-on-dark) 25%, transparent);
  }

  .stat-header {
    display: flex;
    justify-content: flex-end;
  }

  .stat-index {
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--action-primary);
    letter-spacing: var(--letter-spacing-technical);
  }

  .stat-number {
    font-family: var(--font-display);
    font-size: clamp(3rem, 5vw, 4.5rem);
    font-weight: 800;
    color: var(--action-primary);
    letter-spacing: -0.04em;
    line-height: 0.9;
  }

  .stat-label {
    margin-top: var(--space-1);
    font-family: var(--font-heading);
    font-size: var(--fs-body);
    font-weight: 600;
    color: var(--text-on-dark);
    line-height: 1.2;
  }

  .stat-note {
    margin-top: var(--space-2);
    font-family: var(--font-body);
    font-size: 0.6875rem;
    color: var(--text-dim-on-dark);
    letter-spacing: var(--letter-spacing-mono);
    text-transform: uppercase;
    line-height: 1.4;
  }

  @media (min-width: 1024px) {
    .about-inner {
      grid-template-columns: minmax(0, 1.3fr) minmax(0, 1fr);
      gap: var(--space-16);
      align-items: start;
    }

    .about-stats {
      align-self: stretch;
    }
  }
</style>
