---
import { Image } from 'astro:assets';
import { whatsappUrl } from '@data/nav';
import heroImg from '@assets/portfolio/hero-horizontal.png';

const now = new Date();
const dateStr = now.toISOString().slice(0, 10);

const heroStats = [
  { n: '12', u: '+', l: 'Obras entregadas' },
  { n: '04', u: '', l: 'Categorías de proyecto' },
  { n: '16', u: '+', l: 'Años de experiencia' },
  { n: 'BIM', u: '', l: 'Modelado 3D pre-obra' },
];
---
<section id="inicio" class="hero">
  <div class="hero__bg">
    <Image
      src={heroImg}
      alt=""
      widths={[768, 1280, 1920, 2880]}
      sizes="100vw"
      format="avif"
      quality={68}
      loading="eager"
      fetchpriority="high"
    />
  </div>
  <div class="hero__grid"></div>

  <div class="container hero__content">
    <div class="hero__meta">
      <div class="hero__meta-item">
        <span class="hero__meta-dot"></span>
        CorpoHA · Caracas, VE
      </div>
      <div class="hero__meta-item">Ref. 2026-Q2 · {dateStr}</div>
    </div>

    <h1 class="hero__title">
      Remodelamos tu negocio <em>sin parar</em> tu operación.
    </h1>
    <p class="hero__sub">
      Construcción y remodelación comercial, residencial e industrial en Caracas.
      Proceso BIM, ejecución por fases, cero improvisación.
    </p>
    <div class="hero__ctas">
      <a href={whatsappUrl} class="btn btn--primary" rel="noopener">
        Hablar por WhatsApp <span class="btn__arrow">→</span>
      </a>
      <a href="#portafolio" class="btn btn--ghost">
        Ver obras <span class="btn__arrow">↓</span>
      </a>
    </div>
  </div>

  <div class="container">
    <div class="hero__bottom">
      {heroStats.map((s) => (
        <div class="hero__stat">
          <div class="hero__stat-num">
            {s.n}{s.u && <em>{s.u}</em>}
          </div>
          <div class="hero__stat-label">{s.l}</div>
        </div>
      ))}
    </div>
  </div>
</section>
