---
import { Image } from 'astro:assets';
import { whatsappUrl } from '@data/nav';
import heroImg from '@assets/portfolio/roly-hero.png';
---
<section id="inicio" class="hero">
  <div class="container hero-inner">
    <div class="hero-content">
      <span class="subhead hero-eyebrow">Construcción · Remodelación · Caracas</span>
      <h1 class="hero-title">
        Remodelamos tu negocio<br>
        <span class="accent">sin parar tu operación.</span>
      </h1>
      <p class="hero-sub">
        Construcción y remodelación comercial, residencial e industrial en Caracas.
        Proceso BIM, ejecución por fases, cero improvisación.
      </p>
      <div class="hero-ctas">
        <a href={whatsappUrl} class="btn-primary" rel="noopener">
          Hablar por WhatsApp
        </a>
        <a href="#portafolio" class="btn-secondary">Ver obras</a>
      </div>
    </div>

    <div class="hero-image">
      <Image
        src={heroImg}
        alt="Tienda Roly — interior comercial remodelado con iluminación hexagonal en Caracas"
        widths={[640, 960, 1280, 1600]}
        sizes="(min-width: 1024px) 52vw, 100vw"
        format="avif"
        quality={72}
        loading="eager"
        fetchpriority="high"
      />
      <div class="hero-image-overlay" aria-hidden="true"></div>
      <span class="hero-image-caption">
        Tienda Roly · Caracas
      </span>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: var(--space-16) var(--space-24);
    background: var(--surface-0);
    position: relative;
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    gap: var(--space-12);
  }

  .hero-content {
    max-width: 640px;
  }

  .hero-eyebrow {
    display: inline-block;
    padding-bottom: var(--space-2);
    border-bottom: 2px solid var(--action-primary);
  }

  .hero-title {
    margin-top: var(--space-6);
    font-size: var(--fs-h1);
    line-height: 1.05;
    color: var(--text-primary);
  }

  .hero-title .accent {
    color: var(--text-heading);
  }

  .hero-sub {
    margin-top: var(--space-6);
    font-size: var(--fs-body-lg);
    color: var(--text-secondary);
    max-width: 56ch;
  }

  .hero-ctas {
    margin-top: var(--space-8);
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .hero-image {
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    aspect-ratio: 4 / 5;
  }

  .hero-image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-image-overlay {
    position: absolute;
    inset: 0;
    background: color-mix(in oklch, var(--corpoha-steel-600) 4%, transparent);
    pointer-events: none;
  }

  .hero-image-caption {
    position: absolute;
    bottom: var(--space-4);
    left: var(--space-4);
    padding: var(--space-2) var(--space-4);
    background: color-mix(in oklch, var(--corpoha-navy-900) 92%, transparent);
    color: var(--text-on-dark);
    font-family: var(--font-body);
    font-size: var(--fs-caption);
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-radius: var(--radius-sm);
  }

  @media (min-width: 1024px) {
    .hero {
      padding-block: var(--space-24) var(--space-32);
    }

    .hero-inner {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: var(--space-16);
      align-items: center;
    }

    .hero-image {
      aspect-ratio: 3 / 4;
    }
  }
</style>
