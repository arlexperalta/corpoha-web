---
import { services } from '@data/services';
---
<section id="servicios" class="services">
  <div class="container">
    <div class="sec-head">
      <div>
        <div class="eyebrow sec-head__eyebrow">Qué hacemos</div>
        <h2 class="sec-head__title">Cuatro servicios,<br/>una sola empresa.</h2>
      </div>
      <p class="sec-head__sub">
        Desde remodelaciones comerciales hasta infraestructura nacional.
        Un mismo equipo, un mismo estándar técnico.
      </p>
    </div>

    <div class="services__grid">
      {services.map((s) => (
        <div class="service">
          <div class="service__num">{s.num}/</div>
          <div>
            <h3 class="service__title">{s.title}</h3>
            <p class="service__desc">{s.description}</p>
            <div class="service__tags">
              {s.tags.map((t) => <span class="service__tag">{t}</span>)}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
