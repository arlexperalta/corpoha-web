---
import { services } from '@data/services';

const iconPaths: Record<string, string> = {
  home: 'M3 12l9-9 9 9M5 10v10h4v-6h6v6h4V10',
  building: 'M3 21h18M6 3h12v18H6zM9 7h2M13 7h2M9 11h2M13 11h2M9 15h2M13 15h2',
  clipboard:
    'M9 4h6a1 1 0 011 1v1h2a2 2 0 012 2v12a2 2 0 01-2 2H6a2 2 0 01-2-2V8a2 2 0 012-2h2V5a1 1 0 011-1zM9 12h6M9 16h4',
  structure:
    'M3 3v18h18M7 21V8l5 3V7l5 3v11',
};
---
<section id="servicios" class="services">
  <div class="services-watermark" aria-hidden="true">
    <span class="watermark watermark--outlined watermark-parallax">02</span>
  </div>

  <div class="container">
    <header class="section-header">
      <span class="section-marker">Sección 02 · Servicios</span>
      <h2 class="section-title">
        Cuatro servicios.<br>
        <span class="accent">Un solo estándar técnico.</span>
      </h2>
      <p class="section-lead">
        Desde remodelaciones comerciales hasta infraestructura nacional. Mismo equipo,
        misma disciplina de obra, misma exigencia de entrega.
      </p>
    </header>

    <ul class="services-grid">
      {services.map((service, i) => (
        <li class="service-card reveal-stagger" style={`animation-delay: ${i * 80}ms`}>
          <div class="service-header">
            <span class="service-number">0{i + 1}</span>
            <span class="service-divider" aria-hidden="true"></span>
            <span class="service-label">Servicio</span>
          </div>

          <span class="service-icon" aria-hidden="true">
            <svg
              width="40"
              height="40"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.4"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d={iconPaths[service.icon]} />
            </svg>
          </span>

          <h3 class="service-title">{service.title}</h3>
          <p class="service-description">{service.description}</p>

          <span class="service-underline" aria-hidden="true"></span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .services {
    position: relative;
    background: var(--surface-1);
    border-top: var(--hairline);
    border-bottom: var(--hairline);
    overflow: hidden;
  }

  .services-watermark {
    position: absolute;
    bottom: -6vh;
    left: -4vw;
    pointer-events: none;
    z-index: 0;
  }

  .services-watermark .watermark {
    display: block;
    line-height: 0.85;
  }

  .services :global(.container) {
    position: relative;
    z-index: 1;
  }

  .section-header {
    max-width: 760px;
    margin-bottom: var(--space-16);
  }

  .section-title {
    margin-top: var(--space-4);
    font-size: var(--fs-h1);
    line-height: 1.05;
    letter-spacing: -0.025em;
    text-wrap: balance;
  }

  .section-title .accent {
    color: var(--text-primary);
  }

  .section-lead {
    margin-top: var(--space-6);
    font-size: var(--fs-body-lg);
    color: var(--text-secondary);
    max-width: 58ch;
  }

  .services-grid {
    display: grid;
    gap: 0;
    grid-template-columns: 1fr;
    border-top: var(--hairline-strong);
  }

  .service-card {
    position: relative;
    padding: var(--space-12) var(--space-6);
    border-bottom: var(--hairline-strong);
    transition: background 220ms ease-out;
    cursor: default;
  }

  .service-card:hover {
    background: color-mix(in oklch, var(--action-primary) 6%, transparent);
  }

  .service-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-10);
  }

  .service-number {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.25rem;
    color: var(--action-primary);
    letter-spacing: -0.02em;
  }

  .service-divider {
    flex: 0 0 36px;
    height: 1px;
    background: var(--corpoha-steel-600);
    opacity: 0.4;
  }

  .service-label {
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--text-secondary);
    letter-spacing: var(--letter-spacing-technical);
    text-transform: uppercase;
  }

  .service-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--corpoha-steel-600);
    margin-bottom: var(--space-6);
  }

  .service-title {
    font-size: clamp(1.5rem, 1.2rem + 1vw, 2rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--text-heading);
    font-weight: 700;
    max-width: 20ch;
  }

  .service-description {
    margin-top: var(--space-4);
    color: var(--text-secondary);
    font-size: var(--fs-body);
    max-width: 48ch;
  }

  .service-underline {
    position: absolute;
    bottom: -1px;
    left: 0;
    height: 3px;
    width: 0;
    background: var(--action-primary);
    transition: width 360ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .service-card:hover .service-underline {
    width: 100%;
  }

  @media (min-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr 1fr;
    }

    .service-card {
      padding: var(--space-16) var(--space-12);
    }

    .service-card:nth-child(odd) {
      border-right: var(--hairline-strong);
    }
  }
</style>
