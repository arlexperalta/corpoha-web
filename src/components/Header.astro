---
import { navItems, whatsappUrl } from '@data/nav';
import logoGris from '@assets/logos/logo-gris.svg?raw';
---
<nav class="nav nav--dark" id="site-nav" aria-label="Principal">
  <div class="container nav__inner">
    <a href="#inicio" class="nav__logo" aria-label="Corporación HA — Inicio">
      <span class="nav__logo-mark" set:html={logoGris} />
      <span class="nav__logo-text">
        <span>CORPOHA</span>
        <span class="nav__logo-sub">Corporación HA</span>
      </span>
    </a>

    <div class="nav__links">
      {navItems.map((item) => (
        <a href={item.href} class="nav__link">{item.label}</a>
      ))}
    </div>

    <a href={whatsappUrl} class="nav__cta" rel="noopener">
      Contacto
    </a>

    <button
      class="nav__menu-btn"
      type="button"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="nav-mobile"
      id="nav-toggle"
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
        <line x1="3" y1="6" x2="17" y2="6" class="ic-open"></line>
        <line x1="3" y1="14" x2="17" y2="14" class="ic-open"></line>
        <line x1="4" y1="4" x2="16" y2="16" class="ic-close"></line>
        <line x1="16" y1="4" x2="4" y2="16" class="ic-close"></line>
      </svg>
    </button>
  </div>
</nav>

<nav id="nav-mobile" class="nav__mobile" aria-label="Navegación móvil" hidden>
  {navItems.map((item) => (
    <a href={item.href}>{item.label}</a>
  ))}
  <a href={whatsappUrl} class="nav__mobile-cta" rel="noopener">Contacto →</a>
</nav>

<style>
  .ic-close { display: none; }
  .nav__menu-btn[aria-expanded="true"] .ic-open { display: none; }
  .nav__menu-btn[aria-expanded="true"] .ic-close { display: inline; }
</style>

<script>
  const nav = document.getElementById('site-nav');
  const toggle = document.getElementById('nav-toggle');
  const mobileMenu = document.getElementById('nav-mobile');

  // Scroll: nav background
  const onScroll = () => {
    if (!nav) return;
    if (window.scrollY > 40) {
      nav.classList.add('nav--scrolled');
      nav.classList.remove('nav--dark');
    } else {
      nav.classList.remove('nav--scrolled');
      nav.classList.add('nav--dark');
    }
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // Mobile menu
  if (toggle && mobileMenu) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      toggle.setAttribute('aria-label', expanded ? 'Abrir menú' : 'Cerrar menú');
      if (expanded) {
        mobileMenu.setAttribute('hidden', '');
      } else {
        mobileMenu.removeAttribute('hidden');
      }
    });
    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', 'Abrir menú');
        mobileMenu.setAttribute('hidden', '');
      });
    });
  }
</script>
