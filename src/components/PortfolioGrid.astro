---
import { Image } from 'astro:assets';
import { projects, projectCategories } from '@data/projects';

const categoryCodes: Record<string, string> = {
  comercial: 'COM',
  industrial: 'IND',
  desarrollo: 'DES',
  residencial: 'RES',
};

const padNumber = (n: number) => String(n).padStart(2, '0');
---
<section id="portafolio" class="portfolio">
  <div class="portfolio-watermark" aria-hidden="true">
    <span class="watermark watermark-parallax">03</span>
  </div>

  <div class="container">
    <header class="section-header">
      <div class="section-header-top">
        <span class="section-marker">Sección 03 · Portafolio</span>
        <span class="section-count">12 obras / 4 categorías</span>
      </div>
      <h2 class="section-title">
        De un local de 1 semana<br>
        <span class="accent">a infraestructura nacional.</span>
      </h2>
      <p class="section-lead">
        Cada obra documentada con proceso BIM, cronograma cumplido y estándares
        técnicos verificables. Esto no es marketing — es el trabajo real.
      </p>
    </header>

    <ul class="portfolio-grid">
      {projects.map((project, i) => (
        <li
          class={`portfolio-card reveal-stagger ${i === 0 ? 'portfolio-card--featured' : ''}`}
          style={`animation-delay: ${Math.min(i * 60, 480)}ms`}
        >
          <a href={`#proyecto-${project.id}`} class="portfolio-link" aria-label={`Ver ${project.name}`}>
            <div class="portfolio-image-wrapper">
              <Image
                src={project.image}
                alt={project.imageAlt}
                widths={[400, 600, 900, 1200]}
                sizes={i === 0
                  ? '(min-width: 1024px) 66vw, (min-width: 640px) 100vw, 100vw'
                  : '(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw'}
                format="avif"
                quality={72}
                loading={i < 2 ? 'eager' : 'lazy'}
                class="portfolio-image"
              />
              <div class="portfolio-overlay" aria-hidden="true"></div>

              <div class="portfolio-number-box" aria-hidden="true">
                <span class="portfolio-number">{padNumber(i + 1)}</span>
              </div>

              <div class="portfolio-category-tag">
                <span>{categoryCodes[project.category]}</span>
                <span class="portfolio-category-label">{projectCategories[project.category]}</span>
              </div>
            </div>

            <div class="portfolio-meta">
              <header class="portfolio-meta-header">
                <h3 class="portfolio-title">{project.name}</h3>
                <span class="portfolio-arrow" aria-hidden="true">→</span>
              </header>
              <p class="portfolio-location">{project.location}</p>
              <p class="portfolio-description">{project.description}</p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .portfolio {
    background: var(--surface-0);
    position: relative;
    overflow: hidden;
  }

  .portfolio-watermark {
    position: absolute;
    top: 8vh;
    right: -6vw;
    pointer-events: none;
    z-index: 0;
  }

  .portfolio-watermark .watermark {
    display: block;
    line-height: 0.85;
  }

  .portfolio :global(.container) {
    position: relative;
    z-index: 1;
  }

  .section-header {
    max-width: 880px;
    margin-bottom: var(--space-16);
  }

  .section-header-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: var(--hairline);
  }

  .section-count {
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--text-secondary);
    letter-spacing: var(--letter-spacing-technical);
    text-transform: uppercase;
  }

  .section-title {
    margin-top: var(--space-8);
    font-size: var(--fs-h1);
    line-height: 1.05;
    letter-spacing: -0.025em;
    text-wrap: balance;
  }

  .section-title .accent {
    color: var(--text-primary);
  }

  .section-lead {
    margin-top: var(--space-6);
    font-size: var(--fs-body-lg);
    color: var(--text-secondary);
    max-width: 58ch;
  }

  .portfolio-grid {
    display: grid;
    gap: var(--space-12) var(--space-8);
    grid-template-columns: 1fr;
  }

  .portfolio-card {
    display: flex;
    flex-direction: column;
  }

  .portfolio-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    color: inherit;
  }

  .portfolio-image-wrapper {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 2;
    background: var(--surface-1);
    isolation: isolate;
  }

  .portfolio-image-wrapper :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 500ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .portfolio-card:hover .portfolio-image-wrapper :global(img) {
    transform: scale(1.04);
  }

  .portfolio-overlay {
    position: absolute;
    inset: 0;
    background: color-mix(in oklch, var(--corpoha-steel-600) 5%, transparent);
    pointer-events: none;
    transition: background 220ms ease-out;
  }

  .portfolio-card:hover .portfolio-overlay {
    background: color-mix(in oklch, var(--corpoha-navy-900) 12%, transparent);
  }

  .portfolio-number-box {
    position: absolute;
    top: var(--space-4);
    left: var(--space-4);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2) var(--space-3);
    background: var(--corpoha-paper-50);
    border-bottom: 3px solid var(--action-primary);
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.125rem;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--text-heading);
    transition: transform 260ms ease-out;
  }

  .portfolio-card:hover .portfolio-number-box {
    transform: translateY(-2px);
  }

  .portfolio-category-tag {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
    padding: var(--space-2) var(--space-3);
    background: color-mix(in oklch, var(--corpoha-navy-900) 92%, transparent);
    color: var(--text-on-dark);
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: var(--letter-spacing-technical);
    text-transform: uppercase;
  }

  .portfolio-category-label {
    display: none;
    font-weight: 400;
    opacity: 0.7;
    letter-spacing: var(--letter-spacing-mono);
  }

  .portfolio-meta-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
  }

  .portfolio-title {
    font-size: clamp(1.25rem, 1.1rem + 0.7vw, 1.625rem);
    line-height: 1.1;
    color: var(--text-heading);
    letter-spacing: -0.015em;
    text-wrap: balance;
  }

  .portfolio-arrow {
    font-family: var(--font-body);
    font-size: 1.25rem;
    color: var(--action-primary);
    transition: transform 240ms cubic-bezier(0.4, 0, 0.2, 1);
    flex-shrink: 0;
  }

  .portfolio-card:hover .portfolio-arrow {
    transform: translateX(6px);
  }

  .portfolio-location {
    margin-top: var(--space-1);
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--text-secondary);
    letter-spacing: var(--letter-spacing-technical);
    text-transform: uppercase;
  }

  .portfolio-description {
    margin-top: var(--space-4);
    color: var(--text-secondary);
    font-size: var(--fs-body);
    max-width: 45ch;
  }

  @media (min-width: 640px) {
    .portfolio-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-12) var(--space-8);
    }

    .portfolio-category-label {
      display: inline;
    }
  }

  @media (min-width: 1024px) {
    .portfolio-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-16) var(--space-10);
    }

    .portfolio-card--featured {
      grid-column: span 2;
      grid-row: span 1;
    }

    .portfolio-card--featured .portfolio-image-wrapper {
      aspect-ratio: 16 / 9;
    }

    .portfolio-card--featured .portfolio-title {
      font-size: 2rem;
    }

    .portfolio-card--featured .portfolio-number-box {
      font-size: 1.5rem;
      padding: var(--space-3) var(--space-4);
    }
  }
</style>
