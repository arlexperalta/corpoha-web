---
import { Image } from 'astro:assets';
import { projects, projectCategories } from '@data/projects';
---
<section id="portafolio" class="portfolio">
  <div class="container">
    <header class="section-header">
      <span class="subhead">Obras entregadas</span>
      <h2>Doce proyectos. Cuatro categorías.</h2>
      <p class="section-lead">
        De tiendas comerciales de 1 semana a infraestructura energética en Valles del Tuy.
        Cada obra con proceso BIM y estándares documentados.
      </p>
    </header>

    <ul class="portfolio-grid">
      {projects.map((project) => (
        <li class="portfolio-card reveal">
          <div class="portfolio-image-wrapper">
            <Image
              src={project.image}
              alt={project.imageAlt}
              widths={[400, 600, 900]}
              sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
              format="avif"
              quality={70}
              loading="lazy"
              class="portfolio-image"
            />
            <div class="portfolio-overlay" aria-hidden="true"></div>
          </div>
          <div class="portfolio-meta">
            <span class="portfolio-category">{projectCategories[project.category]}</span>
            <h3 class="portfolio-title">{project.name}</h3>
            <p class="portfolio-location">{project.location}</p>
            <p class="portfolio-description">{project.description}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .portfolio {
    background: var(--surface-0);
  }

  .section-header {
    max-width: 720px;
    margin-bottom: var(--space-16);
  }

  .section-header h2 {
    margin-top: var(--space-3);
  }

  .section-lead {
    margin-top: var(--space-4);
    font-size: var(--fs-body-lg);
    color: var(--text-secondary);
  }

  .portfolio-grid {
    display: grid;
    gap: var(--space-8);
    grid-template-columns: 1fr;
  }

  .portfolio-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .portfolio-image-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-md);
    aspect-ratio: 3 / 2;
    background: var(--surface-1);
    transition: transform 180ms ease-out;
  }

  .portfolio-card:hover .portfolio-image-wrapper {
    transform: scale(1.02);
  }

  .portfolio-image-wrapper :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 260ms ease-out;
  }

  .portfolio-overlay {
    position: absolute;
    inset: 0;
    background: color-mix(in oklch, var(--corpoha-steel-600) 4%, transparent);
    pointer-events: none;
    transition: background 180ms ease-out;
  }

  .portfolio-card:hover .portfolio-overlay {
    background: color-mix(in oklch, var(--corpoha-steel-600) 12%, transparent);
  }

  .portfolio-category {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--fs-caption);
    font-weight: 500;
    color: var(--action-primary);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .portfolio-title {
    margin-top: var(--space-2);
    font-size: var(--fs-h3);
    color: var(--text-heading);
  }

  .portfolio-location {
    margin-top: var(--space-1);
    font-size: var(--fs-caption);
    color: var(--text-secondary);
  }

  .portfolio-description {
    margin-top: var(--space-3);
    color: var(--text-secondary);
    font-size: var(--fs-body);
  }

  @media (min-width: 640px) {
    .portfolio-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .portfolio-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-12);
    }
  }
</style>
