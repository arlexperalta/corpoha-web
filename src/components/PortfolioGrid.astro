---
import { Image } from 'astro:assets';
import { projects, categoryFilters } from '@data/projects';

const counts: Record<string, number> = { 'Todos': projects.length };
projects.forEach((p) => {
  counts[p.categoryLabel] = (counts[p.categoryLabel] || 0) + 1;
});

const padNumber = (n: number) => String(n).padStart(2, '0');
---
<section id="portafolio" class="portfolio">
  <div class="container">
    <div class="sec-head">
      <div>
        <div class="eyebrow sec-head__eyebrow">Obras entregadas</div>
        <h2 class="sec-head__title">Doce proyectos.<br/>Cuatro categorías.</h2>
      </div>
      <p class="sec-head__sub">
        De tiendas comerciales de 1 semana a infraestructura energética en Valles del Tuy.
        Cada obra con proceso BIM y estándares documentados.
      </p>
    </div>

    <div class="portfolio__filters" role="group" aria-label="Filtros de portafolio">
      {categoryFilters.map((c) => (
        <button
          type="button"
          class={`filter ${c === 'Todos' ? 'filter--active' : ''}`}
          data-filter={c}
        >
          {c}<span class="filter__count">[{counts[c] ?? 0}]</span>
        </button>
      ))}
    </div>

    <div class="portfolio__grid">
      {projects.map((p, i) => (
        <article class="card" data-category={p.categoryLabel} data-id={p.id}>
          <div class="card__img">
            <Image
              src={p.image}
              alt={p.imageAlt}
              widths={[320, 480, 640, 800]}
              sizes="(min-width: 1200px) 25vw, (min-width: 768px) 33vw, (min-width: 480px) 50vw, 100vw"
              format="avif"
              quality={72}
              loading="lazy"
            />
            <div class="card__img-overlay" aria-hidden="true"></div>

            <div class="card__hover" aria-hidden="true">
              <div class="card__hover-code">PR-{padNumber(i + 1)} · {p.year}</div>
              <div class="card__hover-title">{p.name}</div>
              <div class="card__hover-meta">
                {p.area !== '—' && <span>{p.area}</span>}
                {p.duration !== '—' && <span>· {p.duration}</span>}
              </div>
            </div>
          </div>
          <div class="card__body">
            <span class="card__cat">{p.categoryLabel}</span>
            <h3 class="card__name">{p.name}</h3>
            <div class="card__loc">{p.location} · {p.year}</div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .portfolio__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2px;
    background: var(--paper-200);
  }

  .card {
    background: var(--paper-50);
    padding: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
    transition: transform 0.3s ease;
  }

  .card__img {
    aspect-ratio: 4/3;
    position: relative;
    overflow: hidden;
    background: var(--navy);
    isolation: isolate;
  }

  .card__img :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .card:hover .card__img :global(img) {
    transform: scale(1.04);
  }

  .card__img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(0, 10, 91, 0.35) 100%);
    pointer-events: none;
  }

  .card__hover {
    position: absolute;
    inset: 0;
    background: rgba(249, 178, 51, 0.94);
    opacity: 0;
    transition: opacity 0.3s ease;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 20px;
    color: var(--amber-ink);
    gap: 6px;
    pointer-events: none;
  }

  .card:hover .card__hover {
    opacity: 1;
  }

  .card__hover-code {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.75;
  }

  .card__hover-title {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.1;
  }

  .card__hover-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.8;
    margin-top: 4px;
    display: flex;
    gap: 6px;
  }

  .card__body {
    padding: 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .card__cat {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--amber-ink);
    background: var(--amber);
    display: inline-block;
    padding: 3px 8px;
    width: fit-content;
  }

  .card__name {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.2;
    color: var(--ink-950);
  }

  .card__loc {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--steel);
    letter-spacing: 0.06em;
  }
</style>

<script>
  const filters = document.querySelectorAll<HTMLButtonElement>('.filter');
  const cards = document.querySelectorAll<HTMLElement>('.card');

  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filterValue = btn.dataset.filter || 'Todos';
      filters.forEach((b) => b.classList.toggle('filter--active', b === btn));
      cards.forEach((c) => {
        const cat = c.dataset.category;
        const show = filterValue === 'Todos' || cat === filterValue;
        c.style.display = show ? '' : 'none';
      });
    });
  });
</script>
