---
import { Image } from 'astro:assets';
import { projects, categoryFilters } from '@data/projects';

const counts: Record<string, number> = { 'Todos': projects.length };
projects.forEach((p) => {
  counts[p.categoryLabel] = (counts[p.categoryLabel] || 0) + 1;
});

const padNumber = (n: number) => String(n).padStart(2, '0');
---
<section id="portafolio" class="portfolio">
  <div class="container">
    <div class="sec-head">
      <div>
        <div class="eyebrow sec-head__eyebrow">Obras entregadas</div>
        <h2 class="sec-head__title">Doce proyectos.<br/>Cuatro categorías.</h2>
      </div>
      <p class="sec-head__sub">
        De tiendas comerciales de 1 semana a infraestructura energética en Valles del Tuy.
        Cada obra con proceso BIM y estándares documentados.
      </p>
    </div>

    <div class="portfolio__filters" role="group" aria-label="Filtros de portafolio">
      {categoryFilters.map((c, i) => (
        <button
          type="button"
          class={`filter ${c === 'Todos' ? 'filter--active' : ''}`}
          data-filter={c}
        >
          {c}<span class="filter__count">[{counts[c] ?? 0}]</span>
        </button>
      ))}
    </div>

    <div class="portfolio__list">
      {projects.map((p, i) => (
        <div
          class="project"
          data-category={p.categoryLabel}
          data-id={p.id}
        >
          <div class="project__num">{padNumber(i + 1)}</div>
          <div class="project__head">
            <h3 class="project__name">{p.name}</h3>
            <div class="project__loc">{p.location} · {p.year}</div>
          </div>
          <p class="project__desc">{p.description}</p>
          <div class="project__cat">
            {p.categoryLabel}<br/>
            <span class="project__cat-hint">[ ver detalle + ]</span>
          </div>

          <div class="project__expand">
            <div class="project__expand-inner">
              <div class="project__img">
                <Image
                  src={p.image}
                  alt={p.imageAlt}
                  widths={[400, 600, 900]}
                  sizes="(min-width: 768px) 60vw, 100vw"
                  format="avif"
                  quality={72}
                  loading="lazy"
                />
              </div>
              <div class="project__meta">
                <div>
                  <div class="project__meta-label">Código</div>
                  <div class="project__meta-val mono">PR-{padNumber(i + 1)}</div>
                </div>
                <div>
                  <div class="project__meta-label">Año</div>
                  <div class="project__meta-val mono">{p.year}</div>
                </div>
                <div>
                  <div class="project__meta-label">Ubicación</div>
                  <div class="project__meta-val">{p.location}</div>
                </div>
                <div>
                  <div class="project__meta-label">Categoría</div>
                  <div class="project__meta-val">{p.categoryLabel}</div>
                </div>
                <div>
                  <div class="project__meta-label">Área</div>
                  <div class="project__meta-val mono">{p.area}</div>
                </div>
                <div>
                  <div class="project__meta-label">Duración</div>
                  <div class="project__meta-val mono">{p.duration}</div>
                </div>
                <div style="grid-column: 1 / -1;">
                  <div class="project__meta-label">Alcance</div>
                  <div class="project__meta-val" style="font-size: 13px; color: var(--ink-700); font-weight: 400; line-height: 1.5;">
                    {p.description}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .project__cat-hint {
    opacity: 0.6;
    font-size: 10px;
  }
  .project--open .project__cat-hint::before {
    content: "[ — cerrar ]";
  }
  .project--open .project__cat-hint { font-size: 0; }
  .project--open .project__cat-hint::before { font-size: 10px; }
</style>

<script>
  const filters = document.querySelectorAll<HTMLButtonElement>('.filter');
  const projectsEls = document.querySelectorAll<HTMLElement>('.project');

  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filterValue = btn.dataset.filter || 'Todos';
      filters.forEach((b) => b.classList.toggle('filter--active', b === btn));
      projectsEls.forEach((p) => {
        const cat = p.dataset.category;
        const show = filterValue === 'Todos' || cat === filterValue;
        p.style.display = show ? '' : 'none';
        p.classList.remove('project--open');
      });
    });
  });

  projectsEls.forEach((p) => {
    p.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a, button')) return;
      projectsEls.forEach((other) => {
        if (other !== p) other.classList.remove('project--open');
      });
      p.classList.toggle('project--open');
    });
  });
</script>
