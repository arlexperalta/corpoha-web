---
import { whatsappUrl } from '@data/nav';
---
<section id="contacto" class="contact">
  <div class="contact-watermark" aria-hidden="true">
    <span class="watermark watermark-parallax">06</span>
  </div>

  <div class="container">
    <div class="ruler-divider"></div>

    <div class="contact-inner">
      <div class="contact-meta-top">
        <span class="section-marker">Sección 06 · Contacto</span>
        <span class="contact-coords">10°30′N 66°54′W · Caracas</span>
      </div>

      <h2 class="contact-title">
        ¿Listo para<br>
        <span class="accent">tu obra?</span>
      </h2>
      <p class="contact-lead">
        Cuéntanos de tu proyecto. Respondemos el mismo día hábil.
      </p>

      <div class="contact-action-block">
        <a href={whatsappUrl} class="btn-primary contact-cta" rel="noopener">
          <svg
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
          </svg>
          Escribir por WhatsApp
        </a>

        <span class="contact-response-time">Tiempo de respuesta: 1 día hábil</span>
      </div>

      <dl class="contact-meta">
        <div class="contact-meta-item">
          <dt>Instagram</dt>
          <dd>
            <a href="https://instagram.com/corpoha85" rel="noopener" target="_blank">
              @corpoha85
            </a>
          </dd>
        </div>
        <div class="contact-meta-item">
          <dt>Zona de trabajo</dt>
          <dd>Caracas · Miranda · Anzoátegui<br>Cobertura nacional para proyectos de gran escala</dd>
        </div>
        <div class="contact-meta-item">
          <dt>Servicios</dt>
          <dd>Remodelación · Construcción<br>Consultoría · Cálculo Estructural</dd>
        </div>
      </dl>
    </div>
  </div>
</section>

<style>
  .contact {
    background: var(--surface-0);
    position: relative;
    overflow: hidden;
  }

  .contact-watermark {
    position: absolute;
    top: 8vh;
    right: -6vw;
    pointer-events: none;
    z-index: 0;
  }

  .contact-watermark .watermark {
    display: block;
    line-height: 0.85;
  }

  .contact :global(.container) {
    position: relative;
    z-index: 1;
  }

  .ruler-divider {
    margin-block: 0 var(--space-16);
  }

  .contact-inner {
    max-width: 960px;
  }

  .contact-meta-top {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: var(--hairline);
  }

  .contact-coords {
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--text-secondary);
    letter-spacing: var(--letter-spacing-technical);
    text-transform: uppercase;
  }

  .contact-title {
    margin-top: var(--space-12);
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.035em;
    color: var(--text-primary);
  }

  .contact-title .accent {
    color: var(--action-primary);
  }

  .contact-lead {
    margin-top: var(--space-6);
    font-size: var(--fs-body-lg);
    color: var(--text-secondary);
    max-width: 42ch;
  }

  .contact-action-block {
    margin-top: var(--space-12);
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
    padding-block: var(--space-6);
    border-top: var(--hairline);
    border-bottom: var(--hairline);
  }

  .contact-cta {
    font-size: var(--fs-body-lg);
    padding-block: var(--space-4);
    padding-inline: var(--space-8);
  }

  .contact-response-time {
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--text-secondary);
    letter-spacing: var(--letter-spacing-technical);
    text-transform: uppercase;
  }

  .contact-meta {
    margin-top: var(--space-12);
    display: grid;
    gap: var(--space-8);
  }

  .contact-meta-item {
    padding: var(--space-4) 0 var(--space-4) 0;
    border-top: var(--hairline);
  }

  .contact-meta-item dt {
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--action-primary);
    letter-spacing: var(--letter-spacing-technical);
    text-transform: uppercase;
  }

  .contact-meta-item dd {
    margin-top: var(--space-3);
    color: var(--text-primary);
    font-size: var(--fs-body);
    line-height: 1.5;
  }

  .contact-meta-item a {
    color: var(--text-primary);
    border-bottom: 1px solid var(--action-primary);
    padding-bottom: 2px;
    transition: color 150ms ease-out;
  }

  .contact-meta-item a:hover {
    color: var(--action-primary);
  }

  @media (min-width: 768px) {
    .contact-meta {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-10);
    }
  }
</style>
