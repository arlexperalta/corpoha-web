---
import { navItems } from '@data/nav';
import logoBlanco from '@assets/logos/logo-blanco.svg?raw';

const currentYear = new Date().getFullYear();

const categoryLinks = [
  { label: 'Comerciales', href: '#portafolio' },
  { label: 'Residenciales', href: '#portafolio' },
  { label: 'Industriales', href: '#portafolio' },
  { label: 'Desarrollo nacional', href: '#portafolio' },
];

const serviceLinks = [
  { label: 'Remodelación', href: '#servicios' },
  { label: 'Construcción', href: '#servicios' },
  { label: 'Consultoría', href: '#servicios' },
  { label: 'Cálculo Estructural', href: '#servicios' },
];
---
<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <div class="footer__brand">
        <div class="nav__logo">
          <span class="nav__logo-mark" set:html={logoBlanco} />
          <span class="nav__logo-text">
            <span>CORPOHA</span>
            <span class="nav__logo-sub">Corporación HA</span>
          </span>
        </div>
        <p class="footer__tagline">
          Construcción y remodelación<br/>
          Caracas · Venezuela
        </p>
      </div>

      <div>
        <div class="footer__col-title">Servicios</div>
        <ul class="footer__col-list">
          {serviceLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <div class="footer__col-title">Obras</div>
        <ul class="footer__col-list">
          {categoryLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <div class="footer__col-title">Legal</div>
        <ul class="footer__col-list">
          <li><a href="/politica-privacidad">Política de privacidad</a></li>
          <li><a href="/terminos">Términos</a></li>
          <li><a href="https://instagram.com/corpoha85" target="_blank" rel="noopener">Instagram ↗</a></li>
        </ul>
      </div>
    </div>

    <div class="footer__bot">
      <div>© {currentYear} Corporación HA · Todos los derechos reservados</div>
      <div>Caracas · VE · RIF pendiente</div>
    </div>
  </div>
</footer>
